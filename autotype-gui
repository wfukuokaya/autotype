#!/usr/bin/env python3
"""
autotype-gui - Standalone native GUI frontend for autotype.

Opens a native macOS window (via pywebview + WebKit) to paste code,
configure settings, and launch autotype. No browser required.
"""
import base64
import json
import os
import re
import subprocess
import sys
import textwrap
import threading

try:
    import webview
except ImportError:
    print("pywebview not found. Installing...")
    subprocess.check_call([sys.executable, "-m", "pip", "install", "pywebview"])
    import webview

AUTOTYPE_PATH = os.path.expanduser("~/.local/bin/autotype")
STAGING_FILE = "/tmp/autotype_code.R"


class Api:
    """Python API exposed to JavaScript via pywebview bridge."""

    def __init__(self):
        self.typing_done = True
        self.typing_error = None
        self.typing_progress = ""
        self.typing_line = 0
        self.typing_total = 0
        self.typing_process = None
        self.spaces_saved = 0

    def start_typing(self, code_b64, wait, delay, pause_every):
        # Decode base64 to recover exact text (preserves backslashes through pywebview bridge)
        code = base64.b64decode(code_b64).decode('utf-8')
        if not code.strip():
            return {"ok": False, "error": "No code to type"}

        # Strip common leading indentation to reduce keystroke count
        original = code
        code = textwrap.dedent(code)
        # Count spaces saved
        orig_spaces = sum(len(l) - len(l.lstrip(' ')) for l in original.split('\n') if l.strip())
        new_spaces = sum(len(l) - len(l.lstrip(' ')) for l in code.split('\n') if l.strip())
        self.spaces_saved = orig_spaces - new_spaces

        with open(STAGING_FILE, "w") as f:
            f.write(code)

        total = len(code.split("\n"))
        self.typing_done = False
        self.typing_error = None
        self.typing_progress = "Starting..."
        self.typing_line = 0
        self.typing_total = total

        def run():
            try:
                proc = subprocess.Popen(
                    [sys.executable, AUTOTYPE_PATH,
                     STAGING_FILE,
                     "--wait", str(wait),
                     "--delay", str(delay),
                     "--pause-every", str(pause_every)],
                    stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                    text=True, bufsize=1
                )
                self.typing_process = proc
                progress_re = re.compile(r'\[(\d+)/(\d+)\]\s+\((\d+)%\)')
                for line in proc.stdout:
                    line = line.rstrip()
                    m = progress_re.search(line)
                    if m:
                        self.typing_line = int(m.group(1))
                        self.typing_total = int(m.group(2))
                        self.typing_progress = f"[{m.group(1)}/{m.group(2)}] ({m.group(3)}%)"
                    elif "pause" in line.lower() or "retry" in line.lower():
                        self.typing_progress += " (pausing...)"
                proc.wait()
                if proc.returncode != 0:
                    self.typing_error = f"autotype exited with code {proc.returncode}"
            except Exception as e:
                self.typing_error = str(e)
            finally:
                self.typing_done = True
                self.typing_process = None

        threading.Thread(target=run, daemon=True).start()
        return {"ok": True, "dedented": self.spaces_saved if self.spaces_saved > 0 else 0}

    def stop_typing(self):
        proc = self.typing_process
        if proc and proc.poll() is None:
            proc.terminate()
            self.typing_error = "Stopped by user"
            self.typing_done = True
            return {"ok": True}
        return {"ok": False, "error": "Not running"}

    def get_status(self):
        return {
            "done": self.typing_done,
            "error": self.typing_error,
            "progress": self.typing_progress,
            "line": self.typing_line,
            "total": self.typing_total,
        }


