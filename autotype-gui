"""


def main():
    api = Api()
    window = webview.create_window(
        'autotype',
        html=HTML,
        js_api=api,
        width=700,
        height=500,
        min_size=(400, 300),
        background_color='#09090b',
    )
    webview.start()


if __name__ == "__main__":
    main()
