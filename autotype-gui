       style="display:none" onchange="loadFile(this)">

<script>
const editor = document.getElementById('editor');
const status = document.getElementById('status');
const linecount = document.getElementById('linecount');
const startBtn = document.getElementById('startBtn');
const stopBtn = document.getElementById('stopBtn');
const progressFill = document.getElementById('progressFill');
let pollInterval = null;

// plain-text paste
editor.addEventListener('paste', function(e) {
  e.preventDefault();
  const text = (e.clipboardData || window.clipboardData).getData('text/plain');
  const s = this.selectionStart, end = this.selectionEnd;
  this.value = this.value.substring(0, s) + text + this.value.substring(end);
  this.selectionStart = this.selectionEnd = s + text.length;
  updateLineCount();
});

editor.addEventListener('input', updateLineCount);
editor.addEventListener('keydown', function(e) {
  if (e.key === 'Tab') {
    e.preventDefault();
    const s = this.selectionStart, end = this.selectionEnd;
    this.value = this.value.substring(0, s) + '  ' + this.value.substring(end);
    this.selectionStart = this.selectionEnd = s + 2;
  }
});
document.addEventListener('keydown', function(e) {
  if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') { startTyping(); e.preventDefault(); }
  if (e.key === 'Escape') { stopTyping(); }
});

function updateLineCount() {
  const n = (editor.value.match(/\n/g) || []).length + (editor.value ? 1 : 0);
  linecount.textContent = n + ' lines';
}

function openFile() { document.getElementById('fileInput').click(); }

function loadFile(input) {
  const f = input.files[0];
  if (!f) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    editor.value = e.target.result;
    updateLineCount();
    status.textContent = 'loaded ' + f.name;
  };
  reader.readAsText(f);
  input.value = '';
}

function setRunning(running) {
  startBtn.disabled = running;
  startBtn.style.display = running ? 'none' : '';
  stopBtn.style.display = running ? '' : 'none';
  if (running) {
    progressFill.classList.add('active');
  } else {
    progressFill.classList.remove('active');
    progressFill.style.width = '0%';
  }
}

async function stopTyping() {
  try { await window.pywebview.api.stop_typing(); } catch(e) {}
  if (pollInterval) { clearInterval(pollInterval); pollInterval = null; }
  setRunning(false);
  status.textContent = 'stopped';
}

async function startTyping() {
  const code = editor.value;
  if (!code.trim()) { status.textContent = 'nothing to type'; return; }

  setRunning(true);
  const wait = document.getElementById('wait').value;
  status.textContent = 'starting...';

  try {
    // Base64-encode to preserve backslashes through pywebview bridge
    const encoded = btoa(unescape(encodeURIComponent(code)));
    const data = await window.pywebview.api.start_typing(
      encoded, wait,
      document.getElementById('delay').value,
      document.getElementById('pause').value
    );
    if (data.ok) {
      status.textContent = wait + 's countdown' + (data.dedented ? ' (dedented ' + data.dedented + ' sp)' : '');
      pollInterval = setInterval(async () => {
        try {
          const s = await window.pywebview.api.get_status();
          if (s.total > 0) {
            const pct = Math.round(s.line / s.total * 100);
            progressFill.style.width = pct + '%';
          }
          if (s.progress) { status.textContent = s.progress; }
          if (s.done) {
            clearInterval(pollInterval); pollInterval = null;
            progressFill.style.width = s.error ? '0%' : '100%';
            progressFill.classList.remove('active');
            status.textContent = s.error ? s.error : 'done ' + s.total + ' lines';
            setRunning(false);
          }
        } catch(e) { clearInterval(pollInterval); pollInterval = null; setRunning(false); }
      }, 500);
    } else {
      status.textContent = data.error;
      setRunning(false);
    }
  } catch(e) {
    status.textContent = e.message;
    setRunning(false);
  }
}
</script>
</body>
